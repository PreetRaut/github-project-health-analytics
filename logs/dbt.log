    create  table
      "stripe_analytics"."main"."revenue_metrics__dbt_tmp"
  
    as (
      with invoices as (
    select *
    from "stripe_analytics"."main"."stg_invoices"
),

subscriptions as (
    select *
    from "stripe_analytics"."main"."stg_subscriptions"
),

monthly_revenue as (
    select
        date_trunc('month', created_at) as revenue_month,
        currency,
        count(distinct invoice_id) as total_invoices,
        count(distinct customer_id) as paying_customers,
        sum(amount_paid) as revenue
    from invoices
    where paid = true
    group by 1, 2
),

active_subscriptions as (
    select
        currency,
        count(distinct subscription_id) as active_subscriptions,
        sum(
            case
                when billing_interval = 'year' then unit_amount / 12
                else unit_amount
            end * coalesce(quantity, 1)
        ) as estimated_mrr
    from subscriptions
    where status = 'active'
    group by 1
)

select
    mr.revenue_month,
    mr.currency,
    mr.total_invoices,
    mr.paying_customers,
    mr.revenue,
    act.active_subscriptions,
    act.estimated_mrr,
    act.estimated_mrr * 12 as estimated_arr
from monthly_revenue mr
left join active_subscriptions act
    on mr.currency = act.currency
order by mr.revenue_month
    );
  
  
